generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- CATEGORY ----------
model Category {
  id             String   @id @default(uuid()) @map("category_id")
  categoryName   String   @unique @map("category_name")

  // relations
  subCategories  SubCategory[]
  projects       Project[]

  // ---- mandatory audit columns ----
  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@map("category")
}

// ---------- SUB CATEGORY ----------
model SubCategory {
  id              String   @id @default(uuid()) @map("sub_category_id")
  subCategoryName String   @unique @map("sub_category_name")

  // each sub-category belongs to one category
  categoryId      String   @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id])

  projects        Project[]

  rowCreatedUser  String   @default("system") @map("row_created_user")
  rowCreatedTime  DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser  String   @default("system") @map("row_updated_user")
  rowUpdatedTime  DateTime @updatedAt @map("row_updated_time")

  @@index([categoryId])
  @@map("sub_category")
}

// ---------- APPLICATION AREA ----------
model ApplicationArea {
  id                  String   @id @default(uuid()) @map("application_area_id")
  applicationAreaName String   @unique @map("application_area_name")

  projects            Project[]

  rowCreatedUser      String   @default("system") @map("row_created_user")
  rowCreatedTime      DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser      String   @default("system") @map("row_updated_user")
  rowUpdatedTime      DateTime @updatedAt @map("row_updated_time")

  @@map("application_area")
}

// ---------- PROJECT ----------
model Project {
  id               String   @id @default(uuid()) @map("project_id")
  projectTitle     String   @map("project_title")
  brief            String   @map("brief")
  detailed         String   @map("detailed")

  importanceScore  Int      @map("importance_score")
  scoreBand        String   @map("score_band")
  sellabilityTier  String?  @map("sellability_tier")
  complexity       String?  @map("complexity")
  recommendedPrice Int?     @map("recommended_price")
  discountedPrice  Int?     @map("discounted_price")
  originalPrice    Int?     @map("original_price")
  suggestedTech    String?  @map("suggested_tech")
  suggestedModules String?  @map("suggested_modules")

  // relations (foreign keys)
  categoryId       String           @map("category_id")
  category         Category         @relation(fields: [categoryId], references: [id])

  subCategoryId    String?          @map("sub_category_id")
  subCategory      SubCategory?     @relation(fields: [subCategoryId], references: [id])

  applicationAreaId String?         @map("application_area_id")
  applicationArea   ApplicationArea? @relation(fields: [applicationAreaId], references: [id])

  // inverse relations (added by Hextroq site: enquiries + saved/wishlist)
  enquiries        Enquiry[]
  wishlist         Wishlist[]

  rowCreatedUser   String   @default("system") @map("row_created_user")
  rowCreatedTime   DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser   String   @default("system") @map("row_updated_user")
  rowUpdatedTime   DateTime @updatedAt @map("row_updated_time")

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([applicationAreaId])
  @@index([sellabilityTier])
  @@index([complexity])
  @@index([recommendedPrice])
  @@map("project")
}

// ---------- USER (student accounts) ----------
model User {
  id             String   @id @default(uuid()) @map("user_id")
  email          String   @unique
  passwordHash   String   @map("password_hash")
  name           String
  phone          String?

  enquiries      Enquiry[]
  wishlist       Wishlist[]

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@map("user")
}

// ---------- ENQUIRY (lead capture; forward-compatible with a future Order) ----------
model Enquiry {
  id        String   @id @default(uuid()) @map("enquiry_id")
  name      String
  email     String
  phone     String?
  message   String

  // lifecycle: NEW | CONTACTED | CONVERTED | CLOSED (plain string to match tier/complexity convention)
  status    String   @default("NEW")

  // nullable project -> supports both project-specific and generic contact-form leads
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  // nullable user -> guests can enquire; logged-in students get it auto-linked
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("enquiry")
}

// ---------- WISHLIST (saved projects per user) ----------
model Wishlist {
  id        String   @id @default(uuid()) @map("wishlist_id")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@unique([userId, projectId])
  @@index([userId])
  @@map("wishlist")
}
