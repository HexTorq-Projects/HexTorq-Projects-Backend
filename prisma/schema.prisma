generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- CATEGORY ----------
model Category {
  id             String   @id @default(uuid()) @map("category_id")
  categoryName   String   @unique @map("category_name")

  // relations
  subCategories  SubCategory[]
  projects       Project[]
  offers         Offer[]

  // ---- mandatory audit columns ----
  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@map("category")
}

// ---------- SUB CATEGORY ----------
model SubCategory {
  id              String   @id @default(uuid()) @map("sub_category_id")
  subCategoryName String   @unique @map("sub_category_name")

  // each sub-category belongs to one category
  categoryId      String   @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id])

  projects        Project[]
  offers          Offer[]

  rowCreatedUser  String   @default("system") @map("row_created_user")
  rowCreatedTime  DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser  String   @default("system") @map("row_updated_user")
  rowUpdatedTime  DateTime @updatedAt @map("row_updated_time")

  @@index([categoryId])
  @@map("sub_category")
}

// ---------- APPLICATION AREA ----------
model ApplicationArea {
  id                  String   @id @default(uuid()) @map("application_area_id")
  applicationAreaName String   @unique @map("application_area_name")

  projects            Project[]

  rowCreatedUser      String   @default("system") @map("row_created_user")
  rowCreatedTime      DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser      String   @default("system") @map("row_updated_user")
  rowUpdatedTime      DateTime @updatedAt @map("row_updated_time")

  @@map("application_area")
}

// ---------- PROJECT ----------
model Project {
  id               String   @id @default(uuid()) @map("project_id")
  projectTitle     String   @map("project_title")
  brief            String   @map("brief")
  detailed         String   @map("detailed")

  importanceScore  Int      @map("importance_score")
  scoreBand        String   @map("score_band")
  sellabilityTier  String?  @map("sellability_tier")
  complexity       String?  @map("complexity")
  recommendedPrice Int?     @map("recommended_price")
  discountedPrice  Int?     @map("discounted_price")
  originalPrice    Int?     @map("original_price")
  suggestedTech    String?  @map("suggested_tech")
  suggestedModules String?  @map("suggested_modules")

  // relations (foreign keys)
  categoryId       String           @map("category_id")
  category         Category         @relation(fields: [categoryId], references: [id])

  subCategoryId    String?          @map("sub_category_id")
  subCategory      SubCategory?     @relation(fields: [subCategoryId], references: [id])

  applicationAreaId String?         @map("application_area_id")
  applicationArea   ApplicationArea? @relation(fields: [applicationAreaId], references: [id])

  // inverse relations (added by Hextroq site: enquiries + saved/wishlist)
  enquiries        Enquiry[]
  wishlist         Wishlist[]
  orderItems       OrderItem[]
  offerEntries     OfferProject[]

  rowCreatedUser   String   @default("system") @map("row_created_user")
  rowCreatedTime   DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser   String   @default("system") @map("row_updated_user")
  rowUpdatedTime   DateTime @updatedAt @map("row_updated_time")

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([applicationAreaId])
  @@index([sellabilityTier])
  @@index([complexity])
  @@index([recommendedPrice])
  @@map("project")
}

// ---------- USER (student accounts) ----------
model User {
  id                String   @id @default(uuid()) @map("user_id")
  email             String   @unique
  passwordHash      String?  @map("password_hash")
  googleId          String?  @unique @map("google_id")
  name              String
  phone             String?

  referralCode      ReferralCode?

  enquiries      Enquiry[]
  wishlist       Wishlist[]
  orders         Order[]
  resetTokens    PasswordResetToken[]

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@map("user")
}

// ---------- REFERRAL CODE ----------
model ReferralCode {
  id        String   @id @default(uuid()) @map("referral_code_id")
  code      String   @unique @map("code")
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  earnings  ReferralEarning[]

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@map("referral_code")
}

// ---------- REFERRAL EARNING ----------
model ReferralEarning {
  id          String   @id @default(uuid()) @map("referral_earning_id")
  referralCodeId String @map("referral_code_id")
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  referredName String   @map("referred_name")
  referredEmail String  @map("referred_email")
  projectTitle  String  @map("project_title")
  amount       Int      @default(200)
  status       String   @default("PENDING") @map("status")

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@index([referralCodeId])
  @@map("referral_earning")
}

// ---------- ENQUIRY (lead capture; forward-compatible with a future Order) ----------
model Enquiry {
  id        String   @id @default(uuid()) @map("enquiry_id")
  name      String
  email     String
  phone     String?
  message   String

  // lifecycle: NEW | CONTACTED | CONVERTED | CLOSED (plain string to match tier/complexity convention)
  status    String   @default("NEW")

  // nullable project -> supports both project-specific and generic contact-form leads
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  // nullable user -> guests can enquire; logged-in students get it auto-linked
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("enquiry")
}

// ---------- PASSWORD RESET TOKEN ----------
model PasswordResetToken {
  id        String   @id @default(uuid()) @map("reset_token_id")
  token     String   @unique @map("token")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false) @map("used")

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@index([token])
  @@index([userId])
  @@map("password_reset_token")
}

// ---------- WISHLIST (saved projects per user) ----------
model Wishlist {
  id        String   @id @default(uuid()) @map("wishlist_id")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])

  rowCreatedUser String   @default("system") @map("row_created_user")
  rowCreatedTime DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser String   @default("system") @map("row_updated_user")
  rowUpdatedTime DateTime @updatedAt @map("row_updated_time")

  @@unique([userId, projectId])
  @@index([userId])
  @@map("wishlist")
}

// ---------- ORDER ----------
model Order {
  id                 String    @id @default(uuid()) @map("order_id")
  orderNumber        String    @unique @map("order_number")

  userId    String   @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id])

  status             String    @default("PENDING") @map("status")
  paymentStatus      String    @default("PENDING") @map("payment_status")
  totalAmount        Int       @map("total_amount")
  currency           String    @default("INR")

  // FULL | ADVANCE
  paymentType        String    @default("FULL") @map("payment_type")
  amountPaid         Int       @default(0) @map("amount_paid")
  balanceDue         Int       @default(0) @map("balance_due")

  customerName       String    @map("customer_name")
  customerEmail      String    @map("customer_email")
  customerMobile     String?   @map("customer_mobile")

  // mirrors the most recent OrderPayment attempt, for display continuity
  payPandaPaymentId  String?   @map("pay_panda_payment_id")
  checkoutUrl        String?   @map("checkout_url")
  bankRrn            String?   @map("bank_rrn")
  paidAt             DateTime? @map("paid_at")
  expiresAt          DateTime? @map("expires_at")
  verificationCode   String?   @map("verification_code")
  verificationMessage String?  @map("verification_message")
  referralCode         String?   @map("referral_code")

  items              OrderItem[]
  payments           OrderPayment[]

  rowCreatedUser     String    @default("system") @map("row_created_user")
  rowCreatedTime     DateTime  @default(now()) @map("row_created_time")
  rowUpdatedUser     String    @default("system") @map("row_updated_user")
  rowUpdatedTime     DateTime  @updatedAt @map("row_updated_time")

  @@index([userId])
  @@index([paymentStatus])
  @@index([payPandaPaymentId])
  @@map("order")
}

// ---------- ORDER ITEM ----------
model OrderItem {
  id                   String  @id @default(uuid()) @map("order_item_id")

  orderId              String  @map("order_id")
  order                Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  projectId            String  @map("project_id")
  project              Project @relation(fields: [projectId], references: [id])

  projectTitleSnapshot String  @map("project_title_snapshot")
  unitPrice            Int     @map("unit_price")

  rowCreatedUser       String  @default("system") @map("row_created_user")
  rowCreatedTime       DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser       String  @default("system") @map("row_updated_user")
  rowUpdatedTime       DateTime @updatedAt @map("row_updated_time")

  @@index([orderId])
  @@index([projectId])
  @@map("order_item")
}

// ---------- ORDER PAYMENT (one row per payment attempt: FULL, ADVANCE, or BALANCE) ----------
model OrderPayment {
  id                   String    @id @default(uuid()) @map("order_payment_id")

  orderId              String    @map("order_id")
  order                Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // FULL | ADVANCE | BALANCE
  purpose              String    @map("purpose")
  amount               Int
  // PENDING | SUCCESS | FAILED | EXPIRED
  status               String    @default("PENDING")

  // sent to Pay-Panda as its orderId; distinct per attempt so a second
  // (balance) payment on the same order doesn't collide with the first
  externalOrderId      String    @unique @map("external_order_id")

  payPandaPaymentId    String?   @map("pay_panda_payment_id")
  checkoutUrl          String?   @map("checkout_url")
  bankRrn              String?   @map("bank_rrn")
  paidAt               DateTime? @map("paid_at")
  expiresAt            DateTime? @map("expires_at")
  verificationCode     String?   @map("verification_code")
  verificationMessage  String?   @map("verification_message")

  rowCreatedUser       String    @default("system") @map("row_created_user")
  rowCreatedTime       DateTime  @default(now()) @map("row_created_time")
  rowUpdatedUser       String    @default("system") @map("row_updated_user")
  rowUpdatedTime       DateTime  @updatedAt @map("row_updated_time")

  @@index([orderId])
  @@index([payPandaPaymentId])
  @@map("order_payment")
}

// ---------- OFFER (time-boxed % discount campaign) ----------
model Offer {
  id              String   @id @default(uuid()) @map("offer_id")
  name            String

  // ALL | CATEGORY | SUBCATEGORY | PROJECT
  scopeType       String   @map("scope_type")

  categoryId      String?  @map("category_id")
  category        Category? @relation(fields: [categoryId], references: [id])

  subCategoryId   String?  @map("sub_category_id")
  subCategory     SubCategory? @relation(fields: [subCategoryId], references: [id])

  discountPercent Int      @map("discount_percent")

  // FIXED | PERCENT | null (no pre-booking option for this offer)
  advanceType     String?  @map("advance_type")
  // rupees if advanceType=FIXED, 1-100 if advanceType=PERCENT
  advanceValue    Int?     @map("advance_value")

  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  active          Boolean  @default(true)

  projects        OfferProject[]

  rowCreatedUser  String   @default("system") @map("row_created_user")
  rowCreatedTime  DateTime @default(now()) @map("row_created_time")
  rowUpdatedUser  String   @default("system") @map("row_updated_user")
  rowUpdatedTime  DateTime @updatedAt @map("row_updated_time")

  @@index([scopeType])
  @@index([active])
  @@index([startsAt])
  @@index([endsAt])
  @@map("offer")
}

// ---------- OFFER PROJECT (join table for PROJECT-scoped offers) ----------
model OfferProject {
  id        String  @id @default(uuid()) @map("offer_project_id")

  offerId   String  @map("offer_id")
  offer     Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id])

  @@unique([offerId, projectId])
  @@index([projectId])
  @@map("offer_project")
}
